{
  "rules": {

    // ─── Turnaje (soukromá data vlastníka) ──────────────────────────────────
    // Čtení i zápis povoleny pouze přihlášenému vlastníkovi
    "tournaments": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ─── Veřejný mirror (diváci přes QR/PIN) ────────────────────────────────
    // Čtení: kdokoli (nepřihlášený divák, rodič, ...)
    // Zápis: pouze vlastník turnaje NEBO uživatel který turnaj už vytvořil
    //   - nový turnaj: ownerUid v datech musí být auth.uid
    //   - update:      ownerUid v existujících datech musí být auth.uid
    //                  NEBO uživatel je v joinedUsers (sdílený rozhodčí)
    "public": {
      "$tournamentId": {
        ".read":  true,
        ".write": "auth != null && (
          !data.exists() && newData.child('ownerUid').val() === auth.uid
          || data.exists() && data.child('ownerUid').val() === auth.uid
          || data.exists() && data.child('joinedUsers').child(auth.uid).exists()
        )",

        // Validace meta polí
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },
        "pinHash": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 256"
        },
        "status": {
          ".validate": "newData.isString() && (newData.val() === 'draft' || newData.val() === 'active' || newData.val() === 'finished')"
        },

        // Validace settings
        "settings": {
          "matchDurationMinutes": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 120"
          },
          "breakBetweenMatchesMinutes": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 60"
          },
          "numberOfPitches": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 8"
          }
        },

        // ownerUid nesmí být změněn po vytvoření
        "ownerUid": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128 && (!data.exists() || newData.val() === data.val())"
        },

        // joinedUsers — žádný self-write rule. Zápis povolen pouze pokud jeden
        // z ancestorových .write přechází (owner turnaje přes saveTournamentToFirebase,
        // nebo existující joined-admin). Nový self-join probíhá VÝHRADNĚ přes
        // Cloud Function joinTournamentByPin (admin SDK bypass), která ověří PIN.
        // Bez této restrikce by útočník mohl obejít PIN a udělat si 'admin' roli
        // zápisem `joinedUsers/{auth.uid} = 'admin'`.
        "joinedUsers": {
          "$uid": {
            ".validate": "newData.val() === true || newData.val() === 'admin'"
          }
        },

        // Turnaj nesmí překročit rozumné limity
        "teams": {
          "$teamId": {
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
            },
            // rosterToken musí být v public mirror — roster form ho potřebuje k identifikaci týmu
            "rosterToken": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
            },
            "players": {
              "$playerId": {
                "name": {
                  ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
                },
                "jerseyNumber": {
                  ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999"
                }
              }
            }
          }
        }
      }
    },

    // ─── Chat (diskuze hostů) ─────────────────────────────────────────────────
    // Čtení: kdokoli; Zápis: pouze přihlášení uživatelé, push nových zpráv
    // Max 200 zpráv per turnaj (starší se mažou na klientu)
    "chat": {
      "$tournamentId": {
        ".read": true,
        "$messageId": {
          // Audit 2026-05-23 S-3: write vyžaduje auth na CREATE i DELETE.
          // Dříve `!data.exists()` šlo bez auth → bot spam unauthenticated.
          // Vytvořit může jakýkoli přihlášený user; smazat owner turnaje nebo joined.
          ".write": "(auth != null && !data.exists())
            || (auth != null && newData.val() === null && (
              root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
              || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
            ))",
          ".validate": "newData.hasChildren(['authorName', 'text', 'createdAt'])",
          "authorName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
          },
          "text": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 500"
          },
          "createdAt": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          }
        }
      }
    },

    // ─── Fan Poll (hlasování komu fandíte) ────────────────────────────────────
    // Čtení: kdokoli; Zápis: kdokoli (1 hlas per visitorId); owner může smazat vše (reset)
    "polls": {
      "$tournamentId": {
        ".read": true,
        ".write": "auth != null && newData.val() === null && (
          root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
          || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
        )",
        "$voterId": {
          // Voter musí být auth.uid (nelze hlasovat za někoho jiného, nelze
          // přepsat cizí hlas). Poznámka: tím pádem anonym klient si musí
          // vytvořit Firebase anonymous auth (už děláme) — `auth.uid` pak bude
          // stabilní per-device.
          ".write": "auth != null && $voterId === auth.uid && (!data.exists() || newData.val() === null)",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        }
      }
    },

    // ─── MVP hlasování diváků ──────────────────────────────────────────────────
    // Čtení: kdokoli; Zápis: owner může smazat celý uzel (reset hlasů)
    "mvp-votes": {
      "$tournamentId": {
        ".read": true,
        ".write": "auth != null && newData.val() === null && (
          root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
          || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
        )",
        "$voterId": {
          ".write": "!data.exists() || (auth != null && newData.val() === null && (
            root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
            || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
          ))",
          ".validate": "newData.hasChildren(['teamId', 'playerId', 'playerName'])",
          "teamId":     { ".validate": "newData.isString() && newData.val().length <= 50" },
          "playerId":   { ".validate": "newData.isString() && newData.val().length <= 50" },
          "playerName": { ".validate": "newData.isString() && newData.val().length <= 100" }
        }
      }
    },

    // ─── Ankety v chatu (admin vytváří, diváci hlasují) ────────────────────────
    "chat-polls": {
      "$tournamentId": {
        ".read": true,
        "$pollId": {
          // Vytvořit/smazat může pouze owner nebo joined user
          ".write": "auth != null && (
            root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
            || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
          )"
        }
      }
    },

    // ─── Hlasy v anketách chatu ──────────────────────────────────────────────
    "chat-poll-votes": {
      "$tournamentId": {
        "$pollId": {
          ".read": true,
          ".write": "auth != null && newData.val() === null && (
            root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
            || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
          )",
          "$voterId": {
            // Voter musí být auth.uid (žádné přepsání cizích hlasů, žádné ballot stuffing).
            ".write": "auth != null && $voterId === auth.uid && (!data.exists() || newData.val() === null)",
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          }
        }
      }
    },

    // ─── Soupisky (roster form od trenérů) ─────────────────────────────────────
    // Trenéři zapisují přes odkaz s tokenem. Token se ověřuje na klientu
    // (public mirror obsahuje rosterToken per team).
    // Čtení: pouze owner turnaje (chrání osobní údaje trenérů — jméno, telefon, email)
    // Zápis: pokud roster ještě neexistuje NEBO je auth owner turnaje.
    "rosters": {
      "$tournamentId": {
        // Hromadné čtení všech soupisek: owner turnaje NEBO co-owner (admin v joinedUsers)
        // (chrání osobní údaje trenérů — jméno, telefon, email)
        ".read": "auth != null && (root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).val() === 'admin')",
        "$teamId": {
          // Čtení jednotlivé soupisky: pouze přihlášený uživatel (i anonymně).
          // Trenér klikne na odkaz → klient automaticky provede anonymous sign-in →
          // může načíst roster pro pre-fill. Zabraňuje bulk-scrape PII.
          ".read": "auth != null",
          // První zápis: kdokoli (trenér přes odkaz). Přepis: pouze owner nebo admin turnaje.
          ".write": "!data.exists() || (auth != null && (root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).val() === 'admin'))",
          ".validate": "newData.hasChildren(['coach', 'players', 'submittedAt', 'teamId', 'teamName'])",
          "coach": {
            ".validate": "newData.hasChildren(['name', 'phone'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
            },
            "phone": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "email": {
              ".validate": "newData.isString() && newData.val().length <= 100"
            }
          },
          "players": {
            "$playerId": {
              "name": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
              },
              "jerseyNumber": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999"
              }
            }
          },
          "submittedAt": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "teamId": {
            ".validate": "newData.isString() && newData.val().length <= 50"
          },
          "teamName": {
            ".validate": "newData.isString() && newData.val().length <= 100"
          }
        }
      }
    },

    // ─── Registrace týmů na turnaj ──────────────────────────────────────────
    // Trenér se registruje přes veřejný odkaz. Owner schvaluje / zamítá.
    "registrations": {
      "$tournamentId": {
        ".read": "auth != null && (root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).val() === 'admin')",
        "$registrationId": {
          // Jen owner/admin vidí detaily přihlášky (GDPR: obsahuje telefon+email trenéra).
          // Parent .read pokrývá list, tady explicitně zpřísňujeme single-doc read.
          ".read": "auth != null && (root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).val() === 'admin')",
          ".write": "!data.exists() || (auth != null && (root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).val() === 'admin'))",
          ".validate": "newData.hasChildren(['teamName', 'coachName', 'coachPhone', 'submittedAt'])",
          "teamName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "coachName": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
          },
          "coachPhone": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
          },
          "coachEmail": {
            ".validate": "newData.isString() && newData.val().length <= 100"
          },
          "submittedAt": {
            ".validate": "newData.isString() && newData.val().length <= 30"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    // ─── Live reakce na zápasy (⚽🔥👏😮) ─────────────────────────────────────
    // Čtení: kdokoli; Zápis: kdokoli může inkrementovat, owner může smazat
    "reactions": {
      "$tournamentId": {
        ".read": true,
        ".write": "auth != null && newData.val() === null && (
          root.child('public').child($tournamentId).child('ownerUid').val() === auth.uid
          || root.child('public').child($tournamentId).child('joinedUsers').child(auth.uid).exists()
        )",
        "$matchId": {
          // Povolit zápis jen pokud jde o inkrementaci (newData existuje),
          // smazání celého match subtree smí pouze owner/joined (viz parent rule výše)
          ".write": "auth != null && newData.exists()",
          "$teamId": {
            "$emoji": {
              // Musí růst o 1 (increment-only). Brání přímému zapsání 999999.
              // Audit 2026-05-23 S-5: initial value MUSÍ být 1 (dříve šlo přímo
              // 999999 jako start protože !data.exists() ho akceptoval).
              // Reset na 0 smí jen owner/joined přes parent .write.
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 999999 && ((!data.exists() && newData.val() === 1) || (data.exists() && newData.val() === data.val() + 1))"
            }
          }
        }
      }
    },

    // ─── PIN autentizace (odděleno od public mirror — brání offline brute-force)
    // Čtení: pouze admin SDK (Cloud Functions). Client NESMÍ číst — jinak by
    // útočník stáhl pinHash+pinSalt a provedl offline brute-force 10^6 6-místných PINů.
    // Zápis: pouze owner turnaje (při saveTournamentToFirebase).
    "pin-auth": {
      "$tournamentId": {
        ".read": false,
        ".write": "auth != null && (
          !data.exists() && newData.child('ownerUid').val() === auth.uid
          || data.exists() && data.child('ownerUid').val() === auth.uid
        )",
        "pinHash": { ".validate": "newData.isString() && newData.val().length <= 256" },
        "pinSalt": { ".validate": "newData.isString() && newData.val().length <= 128" },
        "ownerUid": { ".validate": "newData.isString() && (!data.exists() || newData.val() === data.val())" }
      }
    },

    // ─── Katalog turnajů (veřejný seznam pro landing page) ─────────────────
    // Čtení: kdokoli; Zápis: pouze vlastník turnaje
    "catalog": {
      ".read": true,
      "$tournamentId": {
        ".write": "auth != null && (
          !data.exists() && newData.child('ownerUid').val() === auth.uid
          || data.exists() && data.child('ownerUid').val() === auth.uid
        )",
        "name":      { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "ownerUid":  { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
        "status":    { ".validate": "newData.isString() && (newData.val() === 'draft' || newData.val() === 'active' || newData.val() === 'finished')" },
        "teamCount": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" }
      }
    },

    // ─── Katalog zápasů (pro landing page) ──────────────────────────────────
    // Čtení: kdokoli; Zápis: vlastník záznamu
    // Audit 2026-05-23 S-4: přidán validate per pole — storage abuse mitigation
    // (dříve RTDB akceptoval libovolné struktury až 32MB per write).
    "match-catalog": {
      ".read": true,
      "$matchId": {
        ".write": "auth != null && (
          !data.exists() && newData.child('ownerUid').val() === auth.uid
          || data.exists() && data.child('ownerUid').val() === auth.uid
        )",
        "ownerUid":  { ".validate": "newData.isString() && newData.val().length <= 128" },
        "name":      { ".validate": "newData.isString() && newData.val().length <= 200" },
        "clubName":  { ".validate": "newData.isString() && newData.val().length <= 100" },
        "opponent":  { ".validate": "newData.isString() && newData.val().length <= 100" },
        "status":    { ".validate": "newData.isString() && (newData.val() === 'planned' || newData.val() === 'live' || newData.val() === 'finished')" },
        "date":      { ".validate": "newData.isString() && newData.val().length <= 30" },
        "sport":     { ".validate": "newData.isString() && newData.val().length <= 30" },
        "$other":    { ".validate": false }
      }
    },

    // ─── Simple Squads — znovupoužitelné soupisky pro Simple mode ─────────
    // Privátní per-user (bez sharing). Jen owner čte/píše.
    "simple-squads": {
      "$ownerUid": {
        ".read":  "auth != null && auth.uid === $ownerUid",
        ".write": "auth != null && auth.uid === $ownerUid"
      }
    },

    // ─── Veřejný zápas (sdílení s rodiči) ──────────────────────────────────
    // Čtení: kdokoli; Zápis: vlastník zápasu napříč scope (legacy uid + klubový).
    // Audit 2026-05-27 (security P1-1): přidán validate na string pole — omezuje
    // storage abuse přes dlouhé texty na veřejně čitelné cestě. Útočník musí
    // zapsat vlastní ownerUid (write gate), takže nemůže impersonovat; toto
    // brání junk-MB-string zneužití. Plný $other:false lockdown je post-beta
    // (schéma PublicSeasonMatch je rozsáhlé + se vyvíjí).
    "public-matches": {
      "$matchId": {
        ".read": true,
        ".write": "auth != null && (
          root.child('matches').child(auth.uid).child($matchId).exists() ||
          root.child('match-catalog').child($matchId).child('ownerUid').val() === auth.uid ||
          (!data.exists() && newData.child('ownerUid').val() === auth.uid) ||
          (data.exists() && data.child('ownerUid').val() === auth.uid)
        )",
        "ownerUid":            { ".validate": "newData.isString() && newData.val().length <= 128" },
        "opponent":            { ".validate": "newData.isString() && newData.val().length <= 100" },
        "clubName":            { ".validate": "newData.isString() && newData.val().length <= 100" },
        "venue":               { ".validate": "newData.isString() && newData.val().length <= 200" },
        "competition":         { ".validate": "newData.isString() && newData.val().length <= 100" },
        "officialResultsNote": { ".validate": "newData.isString() && newData.val().length <= 500" },
        "officialResultsUrl":  { ".validate": "newData.isString() && newData.val().length <= 500" },
        "veoUrl":              { ".validate": "newData.isString() && newData.val().length <= 500" }
      }
    },

    // ─── Zápasy sezóny ──────────────────────────────────────────────────────
    // Scope key = clubId (sdílený mezi trenéry klubu) NEBO uid (legacy).
    // Multi-trainer modely:
    //   - Klubový: všichni členové klubu (owner/coach) mohou edit
    //   - Cross-team pairing: opoziční trenér (awayCoachUid) po join může edit
    //   - Join window: pokud match má pairing.joinToken a ještě není awayCoachUid,
    //     může se libovolný auth user nárokovat (claim) pozici awayCoach
    "matches": {
      "$scopeId": {
        // Scope-level read: owner nebo klubový člen — umožňuje listovat.
        ".read":  "auth != null && (auth.uid === $scopeId || root.child('clubs').child($scopeId).child('members').child(auth.uid).exists())",
        "$matchId": {
          // Per-match read: owner, klubový člen, nebo již-paired away coach.
          // (Join-window read odstraněn — bez toho away coach nemusí číst pinHash
          // a únik PIN hashe přes veřejný match read je eliminován. Čtení match
          // před joinem probíhá přes Cloud Function `joinMatchPairingByPin`,
          // která má admin SDK bypass.)
          ".read":  "auth != null && (auth.uid === $scopeId || root.child('clubs').child($scopeId).child('members').child(auth.uid).exists() || data.child('pairing').child('awayCoachUid').val() === auth.uid)",
          // Write: owner, klubový member (non-viewer), nebo paired away coach.
          // Už NELZE client-side claim awayCoachUid — musí přes CF.
          ".write": "auth != null && (auth.uid === $scopeId || (root.child('clubs').child($scopeId).child('members').child(auth.uid).exists() && root.child('clubs').child($scopeId).child('members').child(auth.uid).child('role').val() !== 'viewer') || data.child('pairing').child('awayCoachUid').val() === auth.uid)"
        }
      }
    },

    // ─── Cross-team pairing PIN auth (oddělený path — client ho nečte) ────
    // Uloženo admin SDK přes Cloud Function / klient zapisuje jen při vytvoření
    // pozvánky (owner scope). Čtení JEN přes CF (admin SDK bypass).
    // Audit 2026-05-23 S-2: write vyžaduje ownership matche. Dříve `auth != null`
    // umožňovalo komukoli přepsat pinHash cizího zápasu → join with own PIN →
    // privilege escalation na write rights v lineup/scores/goals.
    "match-pairing-auth": {
      ".read": false,
      "$matchId": {
        ".read": false,
        // Owner matche (jeho uid v `matches/{uid}/$matchId`) nebo klub-coach
        // (přes match-catalog.ownerUid). Both kontrolují existenci/ownership.
        ".write": "auth != null && (
          root.child('matches').child(auth.uid).child($matchId).exists()
          || root.child('match-catalog').child($matchId).child('ownerUid').val() === auth.uid
        )",
        ".validate": "newData.hasChildren(['pinHash', 'pinSalt'])",
        "pinHash": { ".validate": "newData.isString() && newData.val().length <= 256" },
        "pinSalt": { ".validate": "newData.isString() && newData.val().length <= 64" },
        "$other": { ".validate": false }
      }
    },

    // ─── Rate limiting state — admin SDK only (audit 2026-05-23 S-7) ─────────
    // Server-side counter pro PIN brute force protection. Client NESMÍ číst/psát —
    // jediné modifikace přes Cloud Functions (rate-limiter.ts).
    "rate-limits": {
      ".read": false,
      ".write": false
    },

    // ─── Kontakty trenérů (klubový scope) ───────────────────────────────────
    "contacts": {
      "$scopeId": {
        ".read":  "auth != null && (auth.uid === $scopeId || root.child('clubs').child($scopeId).child('members').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $scopeId || (root.child('clubs').child($scopeId).child('members').child(auth.uid).exists() && root.child('clubs').child($scopeId).child('members').child(auth.uid).child('role').val() !== 'viewer'))"
      }
    },

    // ─── Uložené tréninky (klubový scope) ───────────────────────────────────
    "trainings": {
      "$scopeId": {
        ".read":  "auth != null && (auth.uid === $scopeId || root.child('clubs').child($scopeId).child('members').child(auth.uid).exists())",
        ".write": "auth != null && (auth.uid === $scopeId || (root.child('clubs').child($scopeId).child('members').child(auth.uid).exists() && root.child('clubs').child($scopeId).child('members').child(auth.uid).child('role').val() !== 'viewer'))"
      }
    },

    // ─── Šablony turnajů ─────────────────────────────────────────────────────
    "templates": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ─── Sdílené klubové workspaces ─────────────────────────────────────────
    // Shared clubs — více trenérů může sdílet jeden klub (owner/coach/viewer)
    // Vytvoření/smazání/správa členství: pouze Cloud Functions (admin SDK bypass)
    // Čtení: všichni členové
    // Zápis obsahu (players, teams, ageCategories, name, logo, color): owner + coach
    // Členství a ownership: server-only (immutable z klienta)
    "clubs": {
      "$clubId": {
        ".read":  "auth != null && data.child('members').child(auth.uid).exists()",
        // Zápis povolen pouze pokud klub už existuje A uživatel je owner nebo coach
        // Tím se zabrání vytváření/mazání klubu z klienta (jen přes CF)
        ".write": "auth != null && data.exists() && data.child('members').child(auth.uid).exists() && data.child('members').child(auth.uid).child('role').val() !== 'viewer'",

        // Immutable fields — jen CF (admin SDK bypass)
        "id":         { ".validate": "!data.exists() || newData.val() === data.val()" },
        "createdBy":  { ".validate": "!data.exists() || newData.val() === data.val()" },
        "createdAt":  { ".validate": "!data.exists() || newData.val() === data.val()" },
        "catalogId":  { ".validate": "!data.exists() || newData.val() === data.val()" },
        "ownership":  { ".validate": "!data.exists() || newData.val() === data.val()" },

        // Členství — immutable z klienta (jen invite/remove přes Cloud Functions)
        "members": {
          "$memberUid": {
            ".validate": "!data.exists() || newData.val() === data.val() || newData.val() === null && false"
          }
        },

        // Validace názvu a barvy
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },
        "color": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        }
      }
    },

    // ─── Ukazatele uživatele na kluby, kterých je členem ────────────────────
    // /users/{uid}/memberOfClubs/{clubId} = role string
    // Píše pouze CF (admin SDK), čte vlastník
    // (rule samotný subtree definován níže v "users")

    // ─── Pozvánky do klubů (PIN-based, podobně jako tournament invites) ─────
    // Write i Read: pouze admin SDK (createClubInvite / joinClubByInvite /
    // listClubInvites CF). Client NEČTE přímo — listování pozvánek jde přes CF.
    "clubInvites": {
      "$inviteId": {
        ".read":  false,
        ".write": false
      }
    },

    // ─── PIN hashe pro klubové invites (oddělené úložiště) ──────────────────
    // Čtení: pouze admin SDK (joinClubByInvite CF). Client NESMÍ číst — brání
    // offline brute-force 6-místného PINu.
    "clubPinAuth": {
      "$inviteId": {
        ".read":  false,
        ".write": false
      }
    },

    // ─── Žádosti o ověřený (oficiální) klub z katalogu ─────────────────────
    // User submit: přihlášený uživatel si může vytvořit vlastní žádost
    // Read/Approve: pouze CF (admin SDK bypass)
    "clubRequests": {
      ".read": false,
      "$requestId": {
        ".write": "auth != null && (
          (!data.exists() && newData.child('requesterUid').val() === auth.uid)
          || (data.exists() && data.child('requesterUid').val() === auth.uid && newData.val() === null)
        )",
        ".validate": "newData.hasChildren(['catalogId', 'catalogName', 'requesterUid', 'requesterName', 'requesterRole', 'status', 'createdAt'])",
        "catalogId":     { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "catalogName":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "requesterUid":  { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
        "requesterName": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "requesterRole": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "evidenceUrl":   { ".validate": "newData.isString() && newData.val().length <= 500" },
        "facrId":        { ".validate": "newData.isString() && newData.val().length <= 50" },
        "status":        { ".validate": "newData.isString() && (newData.val() === 'pending' || newData.val() === 'approved' || newData.val() === 'rejected')" },
        "createdAt":     { ".validate": "newData.isString() && newData.val().length <= 30" }
      }
    },

    // ─── Katalog klubů (Wikidata sync + manuální editace) ──────────────────
    // Čtení: kdokoli (kvůli autocomplete v onboardingu pro nepřihlášené)
    // Zápis: pouze admin SDK (Cloud Functions) — frontend nemůže psát přímo
    "clubsCatalog": {
      ".read": true,
      ".write": false,
      ".indexOn": ["name", "wikidataId"]
    },

    // ─── Pending klub návrhy (od uživatelů) ────────────────────────────────
    // Zápis: přihlášený uživatel může vytvořit nový návrh (svůj submittedBy)
    // Čtení: pouze admin SDK
    "clubsCatalogPending": {
      ".read": false,
      "$submissionId": {
        ".write": "auth != null && (
          (!data.exists() && newData.child('submittedBy').val() === auth.uid)
          || newData.val() === null && data.child('submittedBy').val() === auth.uid
        )",
        ".validate": "newData.hasChildren(['name', 'submittedBy', 'submittedAt'])",
        "name":        { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
        "city":        { ".validate": "newData.isString() && newData.val().length <= 100" },
        "logoUrl":     { ".validate": "newData.isString() && newData.val().length <= 500" },
        "submittedBy": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
        "submittedAt": { ".validate": "newData.isString() && newData.val().length <= 30" }
      }
    },

    // ─── Admin audit log (kdo, kdy, co) ────────────────────────────────────
    // Čtení i zápis: pouze admin SDK (Cloud Functions)
    "adminAuditLog": {
      ".read": false,
      ".write": false
    },

    // ─── Uživatelská data ────────────────────────────────────────────────────
    "users": {
      // Index pro Stripe webhook — findUidByCustomerId dotazuje subscription/stripeCustomerId
      ".indexOn": ["subscription/stripeCustomerId"],
      "$uid": {
        // Číst může jen vlastník
        ".read": "auth != null && auth.uid === $uid",

        // Předplatné — píše pouze server (Firebase Admin SDK v Cloud Functions)
        // Admin SDK pravidla obchází, takže false zde klienty blokuje
        "subscription": {
          ".write": false
        },

        // Bezpečnostní flagy (block, watch) — píše pouze admin SDK
        // Vlastník je smí číst (pro zobrazení blokovaného stavu v UI)
        "flags": {
          ".write": false
        },

        // Ukazatele na kluby, jejichž je uživatel členem — píše pouze CF
        // Hodnota: role ('owner' | 'coach' | 'viewer')
        "memberOfClubs": {
          ".write": false
        },

        // Aktivní klub (pro workspace switcher) — vlastník může měnit
        "activeClubId": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isString() && newData.val().length <= 100 || newData.val() === null"
        },

        // Připojené turnaje (přes PIN) — vlastník může číst i psát
        "joinedTournaments": {
          ".write": "auth != null && auth.uid === $uid"
        },

        // Fakturační profil — vlastník může číst i psát
        "billingProfile": {
          ".write": "auth != null && auth.uid === $uid"
        },

        // Moji tenisoví hráči (individuální mód — rodič / privátní trenér).
        // Flat list sledovaných hráčů. Vlastník může číst i psát.
        "myTennisPlayers": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }

  }
}
