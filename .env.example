# Firebase konfigurace
# Zkopíruj tento soubor jako .env.local a vyplň hodnoty z Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Dev auth bypass — nastav na true pouze pro lokální vývoj
VITE_DEV_AUTH_BYPASS=false

# App Check (reCAPTCHA v3) — získej site key z Google reCAPTCHA Console
# https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=

# App Check debug token pro development — vygeneruj v Firebase Console
# → App Check → Apps → Manage debug tokens
VITE_APPCHECK_DEBUG_TOKEN=
