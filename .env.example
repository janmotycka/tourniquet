# Firebase konfigurace
# Zkopíruj tento soubor jako .env.local a vyplň hodnoty z Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Dev auth bypass — nastav na true pouze pro lokální vývoj
# POZOR: vytváří fake user bez Firebase Auth tokenu → Cloud Functions vrátí 401.
# Pro testování klubů / sdílených dat nech vypnuté a přihlas se reálně.
# V production buildu (npx vite build) se hodnota ignoruje (gated import.meta.env.DEV).
VITE_DEV_AUTH_BYPASS=false

# Dev premium override — VITE_DEV_PREMIUM=1 zapne premium funkce v dev buildu.
# V production buildu se ignoruje (gated import.meta.env.DEV).
VITE_DEV_PREMIUM=

# App Check enforcement — produkce: true, lokální dev: false nebo prázdné.
VITE_ENABLE_APP_CHECK=

# App Check (reCAPTCHA v3) — získej site key z Google reCAPTCHA Console
# https://www.google.com/recaptcha/admin
# Musí být zaregistrované domény: torq.cz, www.torq.cz, *.web.app, localhost
VITE_RECAPTCHA_SITE_KEY=

# App Check debug token pro development — vygeneruj v Firebase Console
# → App Check → Apps → Manage debug tokens
VITE_APPCHECK_DEBUG_TOKEN=

# Sentry error monitoring — získej DSN ze Sentry Console
# https://sentry.io → Settings → Projects → Client Keys (DSN)
VITE_SENTRY_DSN=
