{
  "name": "trenink-functions",
  "description": "Firebase Cloud Functions for Trenink app (Stripe payments)",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "cors": "^2.8.5",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.0.0",
    "nodemailer": "^8.0.3",
    "resend": "^6.9.4",
    "stripe": "^14.14.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^7.0.11",
    "typescript": "^5.4.0"
  },
  "private": true
}
